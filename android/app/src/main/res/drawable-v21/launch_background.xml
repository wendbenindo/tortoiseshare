<?xml version="1.0" encoding="utf-8"?>
<!-- Launch screen avec logo TortoiseShare (Android 5.0+) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Fond bleu TortoiseShare -->
    <item android:drawable="@color/tortoise_primary" />

    <!-- Logo centré avec taille fixe -->
    <item
        android:width="120dp"
        android:height="120dp"
        android:gravity="center">
        <bitmap
            android:gravity="center"
            android:src="@mipmap/ic_launcher" />
    </item>
</layer-list>
